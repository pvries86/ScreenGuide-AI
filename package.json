{
  "name": "screenguide-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "native:publish": "dotnet publish native/MouseHook/MouseHook.csproj -c Release -r win-x64 --self-contained true /p:PublishSingleFile=true /p:IncludeNativeLibrariesForSelfExtract=true",
    "electron:start": "wait-on tcp:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/main.js",
    "electron:dev": "concurrently -k \"npm:dev\" \"npm:electron:start\"",
    "preelectron:build": "npm run native:publish",
    "electron:build": "npm run build && electron-builder --win --config electron-builder.json"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "overrides": {
    "@electron/asar": "^4.2.0",
    "@electron/get": "^5.0.0",
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  }
}
